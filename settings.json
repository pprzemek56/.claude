{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Professional",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cd *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}