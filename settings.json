{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Professional",
  "permissions": {
    "allow": ["Bash(*)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/.venv/bin/python .claude/hooks/bash_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/.venv/bin/python .claude/hooks/file_guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
